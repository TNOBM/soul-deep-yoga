<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="page-intro">
    <div class="eyebrow">A Soul Deep Healing Microdosing Program</div>
    <h1>The Mushroom Circle</h1>
    <p>
        A 6-week private healing experience blending microdosing support with mindfulness,
        somatic healing, and guided integration to help women move through grief, anxiety,
        emotional exhaustion, and major life transitions.
    </p>
    <p style="font-size:0.9rem; font-style:italic; color:var(--mushroom); margin-top:1rem;">
        I do not supply or prescribe plant medicine. I offer a safe, structured, therapeutic
        space to support your journey.
    </p>
    <div class="btn-row">
        <a href="/contact" class="btn">Book a Free Discovery Call</a>
        <a href="/contact" class="btn btn-outline">Join the Waitlist</a>
    </div>
</div>

<section>
    <div class="container narrow">
        <div class="section-heading">
            <span class="eyebrow">Is This Calling to You?</span>
            <h2>This program may be a fit if you're…</h2>
        </div>
        <ul class="soft-list">
            <li>Carrying grief, loss, or a tender chapter of transition</li>
            <li>Experiencing anxiety, heaviness, or emotional overwhelm</li>
            <li>Feeling disconnected from your intuition, voice, or body</li>
            <li>Curious about microdosing as a path toward clarity and healing</li>
            <li>Seeking grounded, compassionate support—not just information</li>
        </ul>
        <p style="text-align:center; font-style:italic; margin-top:2rem; color:var(--clay);">
            If your body whispers yes, you are in the right place.
        </p>
    </div>
</section>

<section class="bg-clay">
    <div class="container">
        <div class="section-heading">
            <span class="eyebrow">What's Included</span>
            <h2>A guided, structured 6-week experience</h2>
        </div>
        <div class="grid">
            <div class="card">
                <h3>Weekly Private Mindfulness Sessions</h3>
                <p>
                    Breath-centered, trauma-informed, personalized to your energy and
                    emotional needs.
                </p>
            </div>
            <div class="card">
                <h3>Microdosing Education + Integration</h3>
                <p>
                    Non-prescriptive guidance to help you find your sweet spot, set
                    intentions, track shifts, navigate emotions, and integrate insights.
                </p>
            </div>
            <div class="card">
                <h3>Somatic & Nervous System Healing</h3>
                <p>
                    Gentle breath and body awareness for grounding and regulation throughout
                    your journey.
                </p>
            </div>
            <div class="card">
                <h3>The Integration Journal</h3>
                <p>
                    Your weekly companion for tracking mood, energy, insights, practices, and
                    emotional shifts.
                </p>
            </div>
            <div class="card">
                <h3>Personalized Daily Practices</h3>
                <p>
                    Short, accessible tools for microdosing and non-microdosing days to help
                    your nervous system stay open, safe, and regulated.
                </p>
            </div>
            <div class="card">
                <h3>Completion Ritual & Support Plan</h3>
                <p>
                    A closing session to help anchor your transformation and guide your next
                    steps after the program.
                </p>
            </div>
        </div>
    </div>
</section>

<section>
    <div class="container">
        <div class="section-heading">
            <span class="eyebrow">How Your 6 Weeks Flow</span>
            <h2>Each session builds with gentle intention</h2>
        </div>
        <div class="weeks">
            <% const weeks = [
                'Grounding, Intention & Calibration',
                'Awareness & Subtle Shifts',
                'Insight & Self-Compassion',
                'Letting Go & Releasing',
                'Integration & Embodiment',
                'Reflection & Closing'
            ]; %>
            <% weeks.forEach(function(title, i) { %>
                <div class="week">
                    <div class="week-num">Week <%= String(i + 1).padStart(2, '0') %></div>
                    <%= title %>
                </div>
            <% }); %>
        </div>
    </div>
</section>

<section class="bg-cream">
    <div class="container narrow">
        <div class="investment">
            <div class="eyebrow" style="font-size:0.75rem; letter-spacing:0.35em; text-transform:uppercase; color:var(--sage); margin-bottom:0.8rem;">Investment</div>
            <h3 style="color:var(--earth);">Private 6-Week Program</h3>
            <div class="price">$750</div>
            <p style="font-size:0.95rem;">Payment plans available.</p>
            <p style="font-size:0.95rem;">
                Semi-private and small-group options may also be available—please inquire.
            </p>
        </div>
    </div>
</section>

<section>
    <div class="container narrow">
        <div class="section-heading">
            <span class="eyebrow">A Note on Safety</span>
            <h2>This space is for education and integration.</h2>
        </div>
        <p>
            I do not sell, provide, or prescribe plant medicine. This program is for
            education, harm reduction, and integration support only.
        </p>
        <p>
            Please consult your healthcare provider about medications and mental health
            considerations. This program is not a substitute for clinical therapy or medical
            treatment.
        </p>
    </div>
</section>

<section class="bg-sage">
    <div class="container narrow">
        <div class="section-heading">
            <span class="eyebrow">Why I Created The Mushroom Circle</span>
            <h2>From my own healing, to yours.</h2>
        </div>
        <p>
            I've walked through grief, trauma, anxiety, divorce, and rebuilding my life from
            the inside out. Yoga therapy and intentional microdosing were profound layers of
            my own healing—helping me soften, reconnect with my body, and hear my own voice
            again.
        </p>
        <p>
            Now, I support women who are ready to step into their own healing, gently and
            intentionally.
        </p>
    </div>
</section>

<%- include('partials/contact-block', {
    eyebrow: 'Ready to Begin?',
    heading: 'If something inside you is stirring…',
    body: "If you feel the nudge—if you're longing for clarity, softness, and deeper grounding—let's explore whether this journey is right for you."
}) %>

<%- include('partials/footer') %>
