<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="page-intro">
    <div class="eyebrow">Let's Connect</div>
    <h1>Begin with one intentional breath.</h1>
    <p>
        Whether you're curious, unsure, or ready to begin—I'd be honored to hear from you.
        Reach out with a question, request a discovery call, or simply say hello.
    </p>
</div>

<section>
    <div class="container">
        <div class="form-wrap">
            <div id="form-success" class="form-success" style="display:none;">
                <div class="eyebrow-sm">Message Received</div>
                <h3>Thank you — your note is on its way.</h3>
                <p>I'll be in touch soon, with care and presence.</p>
                <a href="/" class="btn btn-outline">Return Home</a>
            </div>
            <div id="form-error" class="form-error" style="display:none;"></div>
            <form id="contact-form" method="POST" action="https://formspree.io/f/<%= site.formspreeId %>">
                <div class="form-field">
                    <label for="name">Your Name</label>
                    <input id="name" name="name" type="text" required />
                </div>
                <div class="form-field">
                    <label for="email">Email</label>
                    <input id="email" name="email" type="email" required />
                </div>
                <div class="form-field">
                    <label for="interest">What brings you here?</label>
                    <select id="interest" name="interest">
                        <% const options = [
                            'A free discovery call',
                            'Yoga Therapy Assessment',
                            'Private Yoga (Deep Release, Rest, Breath)',
                            'The Mushroom Circle — 6 Week Program',
                            'Mushroom Circle waitlist',
                            'A general question'
                        ]; %>
                        <% options.forEach(function(opt) { %>
                            <option><%= opt %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="form-field">
                    <label for="message">A little about what you're moving through</label>
                    <textarea id="message" name="message" placeholder="Share as much or as little as feels right…"></textarea>
                </div>
                <!-- Formspree's spam honeypot: real users leave this blank. -->
                <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
                <button type="submit" class="btn">Send Message</button>
            </form>
        </div>
    </div>
</section>

<script>
    (function () {
        var form = document.getElementById('contact-form');
        var successEl = document.getElementById('form-success');
        var errorEl = document.getElementById('form-error');
        if (!form) return;

        form.addEventListener('submit', function (e) {
            e.preventDefault();
            errorEl.style.display = 'none';

            var btn = form.querySelector('button[type="submit"]');
            var originalLabel = btn.textContent;
            btn.textContent = 'Sending…';
            btn.disabled = true;

            fetch(form.action, {
                method: 'POST',
                headers: { 'Accept': 'application/json' },
                body: new FormData(form),
            })
                .then(function (res) {
                    if (res.ok) {
                        form.style.display = 'none';
                        successEl.style.display = 'block';
                        successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        return;
                    }
                    return res.json().then(function (data) {
                        var msg =
                            (data && data.errors && data.errors.map(function (err) { return err.message; }).join(', ')) ||
                            'Something went wrong. Please try again, or email souldeepmi@gmail.com directly.';
                        throw new Error(msg);
                    });
                })
                .catch(function (err) {
                    errorEl.textContent = err.message || 'Something went wrong. Please email souldeepmi@gmail.com directly.';
                    errorEl.style.display = 'block';
                    btn.textContent = originalLabel;
                    btn.disabled = false;
                });
        });
    })();
</script>

<section class="bg-sage">
    <div class="container narrow" style="text-align:center;">
        <div class="section-heading">
            <span class="eyebrow">Prefer Email?</span>
            <h2>I read every message with care.</h2>
        </div>
        <a href="mailto:<%= site.email %>" class="email"><%= site.email %></a>
        <p style="margin-top:1.5rem;">
            All sessions are virtual at this time, which means we can work together from
            wherever you are.
        </p>
    </div>
</section>

<section>
    <div class="container narrow">
        <div class="pull-quote">
            "Your healing can be steady, powerful, and soul-deep."
        </div>
    </div>
</section>

<%- include('partials/footer') %>
