<nav class="nav">
    <div class="nav-inner">
        <a href="/" class="brand">
            <%= site.brand %>
            <span><%= site.tagline %></span>
        </a>
        <ul class="nav-links">
            <% site.nav.forEach(function(item) { %>
                <li>
                    <a href="<%= item.href %>" class="<%= active === item.key ? 'active' : '' %>">
                        <%= item.label %>
                    </a>
                </li>
            <% }); %>
            <li>
                <button class="theme-toggle" type="button" onclick="(function(){var h=document.documentElement;var cur=h.getAttribute('data-theme')||'muted';var next=cur==='muted'?'vibrant':'muted';h.setAttribute('data-theme',next);try{localStorage.setItem('sd-theme',next);}catch(e){}})();" aria-label="Toggle theme">
                    <span class="dot" aria-hidden="true"></span>
                    <span class="label-vibrant">Vibrant</span>
                    <span class="label-muted">Muted</span>
                </button>
            </li>
        </ul>
    </div>
</nav>
