{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "python-static-server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "npx-http-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["-y", "http-server", "-p", "8080", "-c-1"],
      "port": 8080
    },
    {
      "name": "npx-serve",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["-y", "serve", "-l", "3000", "."],
      "port": 3000
    }
  ]
}
